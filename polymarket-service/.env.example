PORT=1110
# Polygon RPC (for redeem/housekeeping). Alchemy/Infura recommended.
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# API key for trading routes (order, cancel, housekeeping, etc). When set, obelisk-core
# must pass x-api-key header (POLYMARKET_TRADING_API_KEY in obelisk-core/.env).
# privateKey is always required in request body — never from env (public-facing service)
# POLYMARKET_TRADING_API_KEY=your-secret-key
